#include <iostream>
#include <string.h>
#include <locale>
using namespace std;
int i, j, l, m, n;
char a[30][10], c;
// Задан массив слов. Определить кол-во слов, в которых встречается буква вводимая с клавиатуры.
int main()
{
    setlocale(LC_ALL, "rus");
    cout << "Введите количество слов n=";
    cin >> n;
    cout << "\n Введите список слов; после каждого слова Enter:\n";
    for (i = 0; i < n; i++)
        cin >> a[i];
    cout << "\nВведите символ c=";
    cin >> c;

    m = 0;
    for (i = 0; i < n; i++) {
        l = strlen(a[i]);
        for (j = 0; j <= l; j++)
            if (a[i][i] == c) {
                m++;
                break;
            }
    }
    cout << "\nРезультат: ";
    cout << "\nКол-во слов в которых есть буква '" << c << "'=" << m;
    cout << "\n\n";
    return 0;
}
